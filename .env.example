# ----- Required (pick at least one) -----
# Get your Fireworks AI API key from https://fireworks.ai
FIREWORKS_API_KEY=

# Or use OpenRouter for Gemma 4 (free tier available)
# Get your key from https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# ----- Caption Generation (Gemma-first for Best Use of Gemma prize) -----
# Provider order when LLM_PROVIDER=auto:
#   1. openrouter (Gemma 4 via OpenRouter) -> if OPENROUTER_API_KEY is set
#   2. fireworks_gemma -> if FIREWORKS_GEMMA_MODEL + FIREWORKS_API_KEY are set
#   3. fireworks -> if FIREWORKS_API_KEY is set
#   4. groq -> if GROQ_API_KEY is set
# Set to "openrouter" for OpenRouter-only, "gemma" for Gemma-only, "fireworks" for non-Gemma, "groq" for dev fallback
LLM_PROVIDER=auto

# Primary Fireworks model (used when Gemma is unavailable or disabled)
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct

# Set this to use Gemma through Fireworks instead of OpenRouter
# Example: accounts/fireworks/models/gemma-3-12b-it
FIREWORKS_GEMMA_MODEL=

# ----- Optional: Groq Fallback -----
# Only needed for Groq Whisper transcription, vision, and LLM fallback
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3

# ----- Transcription -----
TRANSCRIPTION_LANGUAGE=en
TRANSCRIPTION_PROVIDER=auto

# ----- Vision -----
VISUAL_PROVIDER=auto

# ----- Storage & Validation -----
STORAGE_DIR=./data
MIN_VIDEO_DURATION_SECONDS=30
MAX_VIDEO_DURATION_SECONDS=120

# ----- Frontend -----
VITE_API_BASE_URL=http://localhost:8000
